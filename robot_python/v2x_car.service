[Unit]
Description=V2X Car Robot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/v2x/robot_python

# ── Edit AMBULANCE_IP before deploying ───────────────────────────────────────
# Replace 192.168.1.x with the actual IP of the ambulance Pi.
# Find it with: hostname -I   (run on the ambulance Pi)
# Leave blank to run without position sharing (V2X-only emergency mode).
ExecStart=/usr/bin/python3 main_car.py --ambulance-ip 192.168.1.x

Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
